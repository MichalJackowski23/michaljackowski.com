---
interface Props {
  lang?: 'en' | 'pl';
}

const { lang = 'en' } = Astro.props;

const content = {
  en: {
    text: "Prof. Michał Jackowski is a legal scholar and attorney shaping AI governance frameworks at the European level. He combines academic research with practical legal experience — advising on AI regulation, building legal technology, and educating the next generation of AI-aware lawyers.",
    affiliations: [
      "Professor of AI & Law at SWPS and ALK",
      "Visiting Scholar at Cambridge University",
      "Advisor to EU AI Office, CEN-CENELEC, PKN, PIIT, Ministry of Digital Affairs",
      "CEO & Co-founder of AnyLawyer",
      "Partner at DSK Kancelaria"
    ],
    credentials: [
      "Executive MBA — ESCP Europe",
      "Professional Scrum Master I",
      "Certified Business Psychologist"
    ]
  },
  pl: {
    text: "Prof. Michał Jackowski to prawnik i naukowiec kształtujący ramy governance AI na poziomie europejskim. Łączy badania akademickie z praktycznym doświadczeniem prawniczym — doradzając w zakresie regulacji AI, budując technologie prawnicze i kształcąc nowe pokolenie prawników świadomych AI.",
    affiliations: [
      "Profesor AI & Prawo na SWPS i ALK",
      "Visiting Scholar na Cambridge University",
      "Doradca EU AI Office, CEN-CENELEC, PKN, PIIT, Ministerstwa Cyfryzacji",
      "CEO i Współzałożyciel AnyLawyer",
      "Partner w DSK Kancelaria"
    ],
    credentials: [
      "Executive MBA — ESCP Europe",
      "Professional Scrum Master I",
      "Certyfikowany Psycholog Biznesu"
    ]
  }
};

const t = content[lang];
---

<section class="py-16 md:py-20 bg-gray-50">
  <div class="max-w-prose mx-auto px-6 lg:px-12 text-center">
    <p class="text-body text-navy leading-relaxed mb-8">
      {t.text}
    </p>

    <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-small text-slate mb-6">
      {t.affiliations.map((affiliation, index) => (
        <span class="flex items-center">
          {index > 0 && <span class="hidden sm:inline mr-6">·</span>}
          {affiliation}
        </span>
      ))}
    </div>

    <div class="flex flex-wrap justify-center gap-3">
      <button
        onclick="document.getElementById('emba-modal').classList.remove('hidden')"
        class="px-3 py-1 bg-blue/10 text-blue text-caption rounded-full font-medium hover:bg-blue/20 cursor-pointer transition-colors"
      >
        Executive MBA — ESCP Europe
      </button>
      <button
        onclick="document.getElementById('scrum-modal').classList.remove('hidden')"
        class="px-3 py-1 bg-blue/10 text-blue text-caption rounded-full font-medium hover:bg-blue/20 cursor-pointer transition-colors"
      >
        Professional Scrum Master I
      </button>
      <span class="px-3 py-1 bg-blue/10 text-blue text-caption rounded-full font-medium">
        {lang === 'en' ? 'Certified Business Psychologist' : 'Certyfikowany Psycholog Biznesu'}
      </span>
    </div>
  </div>

  <!-- EMBA Modal -->
  <div id="emba-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/80" onclick="this.classList.add('hidden')">
    <div class="relative max-w-4xl max-h-[90vh] p-4">
      <img src="/images/credentials/emba-diploma.png" alt="Executive MBA - ESCP Europe" class="max-w-full max-h-[85vh] object-contain rounded-lg" />
      <button class="absolute top-2 right-2 text-white text-3xl font-bold hover:text-gray-300">&times;</button>
    </div>
  </div>

  <!-- Scrum Modal -->
  <div id="scrum-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/80" onclick="this.classList.add('hidden')">
    <div class="relative max-w-4xl max-h-[90vh] p-4">
      <img src="/images/credentials/scrum-master.png" alt="Professional Scrum Master I" class="max-w-full max-h-[85vh] object-contain rounded-lg" />
      <button class="absolute top-2 right-2 text-white text-3xl font-bold hover:text-gray-300">&times;</button>
    </div>
  </div>
</section>
