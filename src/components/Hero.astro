---
interface Props {
  lang?: 'en' | 'pl';
}

const { lang = 'en' } = Astro.props;

const content = {
  en: {
    title: "Prof. Michał Jackowski",
    tagline: "Legal Scholar · AI Governance Expert · Attorney at Law",
    headline: "Shaping the governance of artificial intelligence at the intersection of law, policy, and practice.",
    ctaPrimary: "About me",
    ctaSecondary: "Get in touch"
  },
  pl: {
    title: "Prof. Michał Jackowski",
    tagline: "Prawnik · Ekspert AI Governance · Adwokat",
    headline: "Kształtowanie governance sztucznej inteligencji na styku prawa, polityki i praktyki.",
    ctaPrimary: "O mnie",
    ctaSecondary: "Kontakt"
  }
};

const t = content[lang];
---

<section class="py-16 md:py-24 lg:py-32">
  <div class="max-w-content mx-auto px-6 lg:px-12">
    <div class="flex flex-col md:flex-row items-center gap-10 md:gap-16">
      <!-- Photo -->
      <div class="flex-shrink-0">
        <div class="w-40 h-40 md:w-52 md:h-52 rounded-full bg-gray-200 overflow-hidden ring-4 ring-gray-100">
          <img
            src="/images/michal-jackowski.jpg"
            alt={t.title}
            class="w-full h-full object-cover object-top"
          />
        </div>
      </div>

      <!-- Content -->
      <div class="text-center md:text-left">
        <h1 class="text-display text-navy mb-3">
          {t.title}
        </h1>

        <p class="text-h2 text-slate mb-6 font-normal">
          {t.tagline}
        </p>

        <p class="text-body text-navy max-w-xl mb-8 leading-relaxed">
          {t.headline}
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
          <a
            href={lang === 'en' ? `/en/contact` : `/pl/kontakt`}
            class="inline-flex items-center justify-center px-6 py-3 bg-blue text-white font-medium rounded-md hover:bg-blue-light transition-colors"
          >
            {t.ctaSecondary}
          </a>
          <a
            href="https://calendar.app.google/HhMAL6Nedi2skE3W8"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-6 py-3 border border-navy text-navy font-medium rounded-md hover:bg-navy hover:text-white transition-colors"
          >
            {lang === 'en' ? 'Book a meeting' : 'Umów spotkanie'}
          </a>
          <a
            href="https://www.linkedin.com/in/michal-jackowski-prof/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-[#0A66C2] text-white font-medium rounded-md hover:bg-[#004182] transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
