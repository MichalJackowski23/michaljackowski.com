---
interface Props {
  lang?: 'en' | 'pl';
}

const { lang = 'en' } = Astro.props;

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white border-b border-gray-200">
  <div class="max-w-content mx-auto px-6 lg:px-12">
    <div class="flex items-center justify-between h-18">
      <!-- Logo / Name -->
      <a href={`/${lang}`} class="text-navy font-semibold text-lg hover:text-blue transition-colors">
        Prof. Michał Jackowski
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center gap-8">
        <a href={lang === 'en' ? `/en/contact` : `/pl/kontakt`} class="text-navy hover:text-blue transition-colors text-sm font-medium">
          {lang === 'en' ? 'Contact' : 'Kontakt'}
        </a>

        <!-- Language Switcher -->
        <div class="flex items-center gap-1 ml-4">
          <a
            href={`/en${currentPath.replace(/^\/(en|pl)/, '')}`}
            class:list={[
              "px-2 py-1 text-sm font-medium rounded transition-colors",
              lang === 'en' ? "bg-navy text-white" : "text-navy hover:bg-gray-100"
            ]}
          >
            EN
          </a>
          <a
            href={`/pl${currentPath.replace(/^\/(en|pl)/, '')}`}
            class:list={[
              "px-2 py-1 text-sm font-medium rounded transition-colors",
              lang === 'pl' ? "bg-navy text-white" : "text-navy hover:bg-gray-100"
            ]}
          >
            PL
          </a>
        </div>
      </nav>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-navy"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <!-- Hamburger icon -->
        <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <!-- Close icon -->
        <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <nav
    id="mobile-menu"
    class="md:hidden hidden bg-white border-b border-gray-200"
  >
    <div class="px-6 py-4 space-y-4">
      <a
        href={lang === 'en' ? `/en/contact` : `/pl/kontakt`}
        class="block text-navy hover:text-blue transition-colors text-base font-medium py-2"
      >
        {lang === 'en' ? 'Contact' : 'Kontakt'}
      </a>

      <!-- Mobile Language Switcher -->
      <div class="flex items-center gap-2 pt-4 border-t border-gray-100">
        <span class="text-sm text-slate mr-2">{lang === 'en' ? 'Language:' : 'Język:'}</span>
        <a
          href={`/en${currentPath.replace(/^\/(en|pl)/, '')}`}
          class:list={[
            "px-3 py-1.5 text-sm font-medium rounded transition-colors",
            lang === 'en' ? "bg-navy text-white" : "text-navy hover:bg-gray-100"
          ]}
        >
          EN
        </a>
        <a
          href={`/pl${currentPath.replace(/^\/(en|pl)/, '')}`}
          class:list={[
            "px-3 py-1.5 text-sm font-medium rounded transition-colors",
            lang === 'pl' ? "bg-navy text-white" : "text-navy hover:bg-gray-100"
          ]}
        >
          PL
        </a>
      </div>
    </div>
  </nav>
</header>

<script is:inline>
  (function() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');

    if (btn && menu && iconOpen && iconClose) {
      btn.addEventListener('click', function() {
        const isOpen = !menu.classList.contains('hidden');

        if (isOpen) {
          menu.classList.add('hidden');
          iconOpen.classList.remove('hidden');
          iconClose.classList.add('hidden');
          btn.setAttribute('aria-expanded', 'false');
        } else {
          menu.classList.remove('hidden');
          iconOpen.classList.add('hidden');
          iconClose.classList.remove('hidden');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    }
  })();
</script>
