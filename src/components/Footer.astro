---
interface Props {
  lang?: 'en' | 'pl';
}

const { lang = 'en' } = Astro.props;

const content = {
  en: {
    columns: [
      {
        title: 'Practice',
        links: [
          { label: 'DSK Kancelaria', href: '/en/practice#dsk' },
          { label: 'AI Projects', href: '/en/practice#projects' }
        ]
      },
      {
        title: 'Governance',
        links: [
          { label: 'EU AI Office', href: '/en/governance#eu-ai-office' },
          { label: 'GRAI', href: '/en/governance#grai' },
          { label: 'ITechLaw', href: '/en/governance#itechlaw' },
          { label: 'PIIT', href: '/en/governance#piit' },
          { label: 'CEN-CENELEC', href: '/en/governance#cen-cenelec' }
        ]
      },
      {
        title: 'Academia',
        links: [
          { label: 'Research', href: '/en/academia#research' },
          { label: 'Publications', href: '/en/academia#publications' },
          { label: 'Global Report', href: 'https://globalailawreport.com', external: true },
          { label: 'OUP Essentials', href: '/en/academia#oup' },
          { label: 'Teaching', href: '/en/academia#teaching' }
        ]
      },
      {
        title: 'Media',
        links: [
          { label: 'Monday Bagel', href: '/en/media#podcast' },
          { label: 'Press Mentions', href: '/en/media#press' }
        ]
      },
      {
        title: 'Startup',
        links: [
          { label: 'AnyLawyer', href: 'https://anylawyer.com', external: true }
        ]
      },
      {
        title: 'Connect',
        links: [
          { label: 'LinkedIn', href: 'https://www.linkedin.com/in/michal-jackowski-prof/', external: true },
          { label: 'Email', href: '/en/contact' },
          { label: 'Speaking', href: '/en/contact#speaking' }
        ]
      }
    ],
    copyright: '© 2026 Prof. Michał Jackowski',
    langSwitch: { en: 'EN', pl: 'PL' }
  },
  pl: {
    columns: [
      {
        title: 'Praktyka',
        links: [
          { label: 'DSK Kancelaria', href: '/pl/praktyka#dsk' },
          { label: 'Projekty AI', href: '/pl/praktyka#projekty' }
        ]
      },
      {
        title: 'Governance',
        links: [
          { label: 'EU AI Office', href: '/pl/governance#eu-ai-office' },
          { label: 'GRAI', href: '/pl/governance#grai' },
          { label: 'ITechLaw', href: '/pl/governance#itechlaw' },
          { label: 'PIIT', href: '/pl/governance#piit' },
          { label: 'CEN-CENELEC', href: '/pl/governance#cen-cenelec' }
        ]
      },
      {
        title: 'Nauka',
        links: [
          { label: 'Badania', href: '/pl/nauka#badania' },
          { label: 'Publikacje', href: '/pl/nauka#publikacje' },
          { label: 'Raport Globalny', href: 'https://globalailawreport.com', external: true },
          { label: 'OUP Essentials', href: '/pl/nauka#oup' },
          { label: 'Dydaktyka', href: '/pl/nauka#dydaktyka' }
        ]
      },
      {
        title: 'Media',
        links: [
          { label: 'Monday Bagel', href: '/pl/media#podcast' },
          { label: 'Wzmianki prasowe', href: '/pl/media#prasa' }
        ]
      },
      {
        title: 'Startup',
        links: [
          { label: 'AnyLawyer', href: 'https://anylawyer.com', external: true }
        ]
      },
      {
        title: 'Kontakt',
        links: [
          { label: 'LinkedIn', href: 'https://www.linkedin.com/in/michal-jackowski-prof/', external: true },
          { label: 'Email', href: '/pl/kontakt' },
          { label: 'Wystąpienia', href: '/pl/kontakt#wystapienia' }
        ]
      }
    ],
    copyright: '© 2026 Prof. Michał Jackowski',
    langSwitch: { en: 'EN', pl: 'PL' }
  }
};

const t = content[lang];
const otherLang = lang === 'en' ? 'pl' : 'en';
const currentPath = Astro.url.pathname;
const otherLangPath = currentPath.replace(`/${lang}/`, `/${otherLang}/`) || `/${otherLang}/`;
---

<footer class="bg-gray-800 text-white py-12 md:py-16">
  <div class="max-w-content mx-auto px-6 lg:px-12">
    <!-- Footer columns -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-8 mb-12">
      {t.columns.map((column) => (
        <div>
          <h4 class="text-small font-semibold text-white mb-4 uppercase tracking-wide">
            {column.title}
          </h4>
          <ul class="space-y-2">
            {column.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-small text-gray-400 hover:text-white transition-colors"
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noopener noreferrer' : undefined}
                >
                  {link.label}
                  {link.external && <span class="ml-1">↗</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Divider -->
    <div class="border-t border-gray-700 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <!-- Copyright -->
        <p class="text-small text-gray-400">
          {t.copyright}
        </p>

        <!-- Language switcher -->
        <div class="flex gap-2">
          <a
            href={`/${lang === 'en' ? 'en' : 'pl'}/`}
            class={`px-3 py-1 text-small rounded ${
              lang === 'en'
                ? 'bg-white text-gray-800 font-medium'
                : 'text-gray-400 hover:text-white'
            }`}
          >
            {t.langSwitch.en}
          </a>
          <a
            href={`/${lang === 'pl' ? 'pl' : 'en'}/`.replace('/en/', '/pl/')}
            class={`px-3 py-1 text-small rounded ${
              lang === 'pl'
                ? 'bg-white text-gray-800 font-medium'
                : 'text-gray-400 hover:text-white'
            }`}
          >
            {t.langSwitch.pl}
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
