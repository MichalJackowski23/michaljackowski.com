---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
---

<BaseLayout title="Practice - Legal Advisory & AI | Prof. Michał Jackowski" lang="en" alternateUrl="/pl/praktyka/">
  <Header lang="en" />
  <main id="main-content">
    <!-- Hero -->
    <section class="py-16 md:py-24 bg-gray-50">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <p class="text-small text-blue font-medium uppercase tracking-wide mb-4">Practice</p>
        <h1 class="text-display text-navy mb-6">Legal Advisory & AI Implementation</h1>
        <p class="text-h2 text-slate max-w-2xl">
          Combining deep legal expertise with practical AI knowledge to help organizations navigate the evolving regulatory landscape.
        </p>
      </div>
    </section>

    <!-- DSK Kancelaria -->
    <section id="dsk" class="py-16 md:py-20">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <img
              src="/images/logos/dsk.png"
              alt="DSK Kancelaria"
              class="h-16 mb-6"
            />
            <h2 class="text-h1 text-navy mb-4">DSK Kancelaria</h2>
            <p class="text-body text-slate mb-6">
              As a Partner at DSK Kancelaria, I lead the firm's technology law practice,
              advising clients on AI regulation, data protection, and digital transformation.
              DSK is one of Poland's leading law firms, combining legal excellence with
              deep industry expertise.
            </p>
            <p class="text-body text-slate mb-6">
              Our team provides comprehensive legal support for technology companies,
              financial institutions, and enterprises implementing AI solutions, ensuring
              compliance with Polish and EU regulations.
            </p>

            <h3 class="text-h2 text-navy mb-3">Areas of Expertise</h3>
            <ul class="space-y-2 text-body text-slate mb-8">
              <li class="flex items-start gap-2">
                <span class="text-blue">•</span>
                AI Act compliance and implementation
              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue">•</span>
                Data Governance (Data Act, Data Governance Act, GDPR)
              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue">•</span>
                Tech M&A and technology transactions
              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue">•</span>
                Cybersecurity (NIS2, DORA, cyber resilience)
              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue">•</span>
                Digital services and platform regulation
              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue">•</span>
                Intellectual property in AI systems
              </li>
            </ul>

            <a
              href="https://dsk-kancelaria.pl/zespol/michal-jackowski/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 bg-blue text-white font-medium rounded hover:bg-blue-light transition-colors"
            >
              View profile at DSK
              <span>↗</span>
            </a>
          </div>

          <div class="bg-gray-100 rounded-lg p-8 md:p-12">
            <h3 class="text-h2 text-navy mb-6">Key Clients</h3>
            <ul class="space-y-4 text-body text-slate">
              <li class="flex items-start gap-3">
                <span class="text-blue text-xl">→</span>
                <span>Technology companies implementing AI solutions</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-blue text-xl">→</span>
                <span>Financial institutions adopting algorithmic systems</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-blue text-xl">→</span>
                <span>Corporations and family businesses implementing digital transformation</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-blue text-xl">→</span>
                <span>Healthcare organizations using AI diagnostics</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-blue text-xl">→</span>
                <span>Public sector entities deploying automated decision-making and modern IT systems</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- AI Projects -->
    <section id="projects" class="py-16 md:py-20 bg-gray-50">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <h2 class="text-h1 text-navy mb-4">AI Implementation Projects</h2>
        <p class="text-body text-slate mb-12 max-w-2xl">
          I advise organizations on the legal aspects of AI implementation, from initial
          risk assessment through deployment and ongoing compliance monitoring.
        </p>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-white p-6 rounded-lg border border-gray-200">
            <div class="text-3xl mb-4">📋</div>
            <h3 class="text-h2 text-navy mb-2">AI Risk Assessment</h3>
            <p class="text-body text-slate">
              Comprehensive evaluation of AI systems under the EU AI Act risk classification framework.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg border border-gray-200">
            <div class="text-3xl mb-4">⚖️</div>
            <h3 class="text-h2 text-navy mb-2">Compliance Strategy</h3>
            <p class="text-body text-slate">
              Development of compliance roadmaps aligned with AI Act requirements and timelines.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg border border-gray-200">
            <div class="text-3xl mb-4">📝</div>
            <h3 class="text-h2 text-navy mb-2">Contract Review</h3>
            <p class="text-body text-slate">
              Review and negotiation of AI vendor contracts, licensing agreements, and SLAs.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg border border-gray-200">
            <div class="text-3xl mb-4">🔒</div>
            <h3 class="text-h2 text-navy mb-2">Data Governance</h3>
            <p class="text-body text-slate">
              Design of data governance frameworks for AI training and deployment.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg border border-gray-200">
            <div class="text-3xl mb-4">👁️</div>
            <h3 class="text-h2 text-navy mb-2">Human Oversight</h3>
            <p class="text-body text-slate">
              Implementation of human oversight mechanisms for high-risk AI systems.
            </p>
          </div>

          <div class="bg-white p-6 rounded-lg border border-gray-200">
            <div class="text-3xl mb-4">📊</div>
            <h3 class="text-h2 text-navy mb-2">Audit & Documentation</h3>
            <p class="text-body text-slate">
              Preparation of technical documentation and audit trails for regulatory compliance.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 md:py-20 bg-navy">
      <div class="max-w-content mx-auto px-6 lg:px-12 text-center">
        <h2 class="text-h1 text-white mb-4">Need Legal Advice on AI?</h2>
        <p class="text-body text-gray-300 mb-8">
          Let's discuss how to navigate AI regulation for your organization.
        </p>
        <a
          href="/en/contact"
          class="inline-block px-8 py-3 bg-white text-navy font-medium rounded hover:bg-gray-100 transition-colors"
        >
          Get in touch
        </a>
      </div>
    </section>
  </main>
  <Footer lang="en" />
</BaseLayout>
