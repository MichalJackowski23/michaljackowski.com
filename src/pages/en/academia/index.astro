        <!-- Commentaries -->
        <h3 class="text-h2 text-navy mb-4">Case Commentaries (Glosses)</h3>
        <div class="space-y-3">
          <div class="bg-white p-4 rounded-lg border border-gray-200">
            <p class="text-body text-navy font-medium">Commentary on Constitutional Tribunal Ruling K 19/14</p>
