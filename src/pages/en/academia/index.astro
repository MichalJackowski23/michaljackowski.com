---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
---

<BaseLayout title="Academia - Research & Publications | Prof. Michał Jackowski" lang="en">
  <Header lang="en" />
  <main>
    <!-- Hero -->
    <section class="py-16 md:py-24 bg-gray-50">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <p class="text-small text-blue font-medium uppercase tracking-wide mb-4">Academia</p>
        <h1 class="text-display text-navy mb-6">Research, Publications & Education</h1>
        <p class="text-h2 text-slate max-w-2xl">
          Advancing the understanding of AI law through academic research, international publications, and teaching the next generation of lawyers.
        </p>
      </div>
    </section>

    <!-- SWPS - Primary Affiliation -->
    <section id="swps" class="py-16 md:py-20">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-small text-blue font-medium uppercase tracking-wide mb-4">Primary Affiliation</p>
            <h2 class="text-h1 text-navy mb-4">SWPS University</h2>
            <p class="text-body text-slate mb-6">
              Professor of Law at the Faculty of Law in Poznań, SWPS University. Teaching and researching
              at the intersection of AI, law, and technology regulation.
            </p>
            <p class="text-body text-slate mb-6">
              Leading academic programmes on artificial intelligence law, data governance,
              and digital transformation in the legal profession.
            </p>
          </div>

          <div class="bg-gray-100 rounded-lg p-8 md:p-12 text-center">
            <div class="text-6xl mb-4">🎓</div>
            <p class="text-h2 text-navy mb-2">Professor of Law</p>
            <p class="text-small text-slate">
              Faculty of Law, Poznań
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Cambridge -->
    <section id="cambridge" class="py-16 md:py-20 bg-gray-50">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <img
              src="/images/logos/cambridge.svg"
              alt="University of Cambridge"
              class="h-16 mb-6"
            />
            <h2 class="text-h1 text-navy mb-4">University of Cambridge</h2>
            <p class="text-body text-slate mb-6">
              As a Visiting Scholar at the Faculty of Law, University of Cambridge, I conduct research
              on AI governance, focusing on constitutional safeguards and human oversight in AI systems.
            </p>

            <a
              href="https://www.law.cam.ac.uk"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 bg-blue text-white font-medium rounded hover:bg-blue-light transition-colors"
            >
              Cambridge Faculty of Law
              <span>↗</span>
            </a>
          </div>

          <div class="bg-white rounded-lg p-8 md:p-12 text-center border border-gray-200">
            <div class="text-6xl mb-4">🏛️</div>
            <p class="text-h2 text-navy mb-2">Visiting Scholar</p>
            <p class="text-small text-slate">
              Faculty of Law
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ALK & CLAIRE -->
    <section id="affiliations" class="py-16 md:py-20">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <h2 class="text-h1 text-navy mb-8">Academic Affiliations</h2>
        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-white p-6 rounded-lg border border-gray-200">
            <h3 class="text-h2 text-navy mb-2">Akademia Leona Koźmińskiego</h3>
            <p class="text-small text-blue mb-4">Lecturer — AI & Law Postgraduate Programme</p>
            <p class="text-body text-slate mb-4">
              Teaching on the postgraduate programme in AI Law, one of Central Europe's leading
              practice-oriented educational initiatives in AI & law.
            </p>
            <a
              href="https://www.kozminski.edu.pl/pl/oferta-edukacyjna/studia-podyplomowe/prawo-sztucznej-inteligencji"
              target="_blank"
              rel="noopener noreferrer"
              class="text-small text-blue font-medium hover:underline"
            >
              View programme →
            </a>
          </div>

          <div class="bg-white p-6 rounded-lg border border-gray-200">
            <h3 class="text-h2 text-navy mb-2">CLAIRE — Centre for LegalTech and AI Research</h3>
            <p class="text-small text-blue mb-4">Member of Scientific Council</p>
            <p class="text-body text-slate mb-4">
              Member of the Scientific Council of CLAIRE (Centrum Badań nad LegalTech i AI)
              at the University of Łódź, advancing research in legal technology and AI.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Guest Lecture Programs -->
    <section id="guest-lectures" class="py-16 md:py-20 bg-gray-50">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <h2 class="text-h1 text-navy mb-6">Guest Lecture Programs</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <a href="https://szkolaprzywodztwa.pl/edycje/vii-edycja/" target="_blank" rel="noopener noreferrer" class="bg-white p-6 rounded-lg border border-gray-200 hover:border-blue transition-colors">
            <img src="/images/logos/spiw.svg" alt="Szkoła Przywództwa i Wolności" class="h-16 mb-4 object-contain" />
            <h4 class="text-body text-navy font-medium mb-2">Leadership School VII Edition</h4>
            <p class="text-small text-slate">Szkoła Przywództwa i Wolności — lecture on impact of war in Ukraine.</p>
          </a>
          <a href="https://szkolaprzywodztwa.pl/edycje/viii-edycja/" target="_blank" rel="noopener noreferrer" class="bg-white p-6 rounded-lg border border-gray-200 hover:border-blue transition-colors">
            <img src="/images/logos/spiw.svg" alt="Szkoła Przywództwa i Wolności" class="h-16 mb-4 object-contain" />
            <h4 class="text-body text-navy font-medium mb-2">Leadership School VIII Edition</h4>
            <p class="text-small text-slate">Szkoła Przywództwa i Wolności — lecture on impact of AI development on business and law.</p>
          </a>
          <a href="https://euas.eu/microcredential/ai_and_machine_learning_accelerator/" target="_blank" rel="noopener noreferrer" class="bg-white p-6 rounded-lg border border-gray-200 hover:border-blue transition-colors">
            <img src="/images/logos/euas.svg" alt="EUAS" class="h-12 mb-4 object-contain" />
            <h4 class="text-body text-navy font-medium mb-2">AI & Machine Learning Accelerator</h4>
            <p class="text-small text-slate">Estonian Entrepreneurship University of Applied Sciences — microcredential program.</p>
          </a>
        </div>
      </div>
    </section>

    <!-- Global Report -->
    <section id="global-report" class="py-16 md:py-20">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div class="order-2 md:order-1 bg-white rounded-lg p-8 md:p-12 border border-gray-200">
            <div class="text-5xl mb-4">📊</div>
            <h3 class="text-h2 text-navy mb-4">Key Findings</h3>
            <ul class="space-y-3 text-body text-slate">
              <li class="flex items-start gap-2">
                <span class="text-blue">→</span>
                First international empirical study on AI in legal practice
              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue">→</span>
                Survey of law firms across multiple jurisdictions
              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue">→</span>
                Analysis of AI adoption patterns and barriers
              </li>
              <li class="flex items-start gap-2">
                <span class="text-blue">→</span>
                Recommendations for legal profession
              </li>
            </ul>
          </div>

          <div class="order-1 md:order-2">
            <p class="text-small text-blue font-medium uppercase tracking-wide mb-4">Featured Publication</p>
            <h2 class="text-h1 text-navy mb-4">Global Report on AI in Legal Practice</h2>
            <p class="text-body text-slate mb-6">
              The largest international empirical study examining how law firms around the world
              are adopting artificial intelligence. Survey of law firms across 60+ jurisdictions
              analyzing patterns, barriers, and future outlook for AI in professional services.
            </p>
            <p class="text-body text-slate mb-4">
              Published in collaboration with CCBE, FBI, AIJA, World Jurists Association, and ITechLaw.
            </p>
            <p class="text-body text-navy font-medium mb-8">
              📢 2nd Edition launching soon — with 2025 research data comparing results with the first report.
            </p>

            <a
              href="https://globalailawreport.com"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 bg-blue text-white font-medium rounded hover:bg-blue-light transition-colors"
            >
              Read the Report
              <span>↗</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Publications -->
    <section id="publications" class="py-16 md:py-20">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <h2 class="text-h1 text-navy mb-8">Publications</h2>

        <div class="grid md:grid-cols-2 gap-8 mb-12">
          <!-- OUP -->
          <div id="oup" class="bg-white p-6 rounded-lg border border-gray-200">
            <img
              src="/images/logos/oup.png"
              alt="Oxford University Press"
              class="h-10 mb-4"
            />
            <h3 class="text-h2 text-navy mb-2">Oxford University Press</h3>
            <p class="text-small text-blue mb-2">Editor-in-Chief — OUP Essentials Series</p>
            <p class="text-body text-slate mb-4">
              Editor-in-Chief of OUP Essentials series on legal tech and AI,
              providing accessible yet rigorous analysis of complex legal issues.
            </p>
          </div>

          <!-- Other Publications -->
          <div class="bg-white p-6 rounded-lg border border-gray-200">
            <div class="text-3xl mb-4">📚</div>
            <h3 class="text-h2 text-navy mb-2">70+ Publications</h3>
            <p class="text-body text-slate mb-4">
              Author of monographs, book chapters, and journal articles on constitutional law,
              AI governance, data protection, and technology regulation.
            </p>
          </div>
        </div>

        <!-- Forthcoming -->
        <h3 class="text-h2 text-navy mb-4">Forthcoming</h3>
        <div class="bg-blue/5 p-6 rounded-lg mb-8">
          <ul class="space-y-3 text-body text-slate">
            <li>• "Human Oversight as a Constitutional Safeguard in AI Governance: Convergence or Parallel Evolution?" — ICON-S Conference 2026, Dublin</li>
            <li>• Commentary on Articles 41, 42, 44, 45, 47, 48, 49 AI Act — in: AI Act Commentary (ed. Bieda, Lubasz, Namysłowska, Okoń)</li>
            <li>• Second Global Report on the State of AI in Legal Practice (2025/2026)</li>
            <li>• "AI and Corporate Responsibility – From Fragmented Compliance to Unified Governance" — Cambridge Forum on AI: Law and Governance (with Jarosław Greser)</li>
          </ul>
        </div>

        <!-- Monographs -->
        <h3 class="text-h2 text-navy mb-4">Monographs</h3>
        <div class="space-y-3 mb-8">
          <div class="bg-white p-4 rounded-lg border border-gray-200">
