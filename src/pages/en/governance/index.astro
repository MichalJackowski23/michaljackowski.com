---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

const organizations = [
  {
    id: 'eu-ai-office',
    name: 'EU AI Office',
    role: 'Advisor',
    description: 'Member of expert group drafting The General-Purpose AI Code of Practice and Code of Practice on marking and labelling of AI-generated content. Contributing to the development and implementation of the EU AI Act, advising on regulatory frameworks and governance mechanisms for artificial intelligence at the European level.',
    logo: '/images/logos/eu-ai-office.svg',
    links: [
      { label: 'GPAI Code of Practice', url: 'https://digital-strategy.ec.europa.eu/en/policies/contents-code-gpai' },
      { label: 'AI-Generated Content Code', url: 'https://digital-strategy.ec.europa.eu/en/policies/code-practice-ai-generated-content' }
    ]
  },
  {
    id: 'grai',
    name: 'GRAI',
    role: 'Leader',
    description: 'Leader of the AI Working Group (Grupa Robocza ds. Sztucznej Inteligencji) at the Ministry of Digital Affairs, supporting the Polish government in AI policy. Shaping Poland\'s national AI strategy and international cooperation.',
    logo: '/images/logos/grai.png',
    link: 'https://ai.gov.pl/grupa-robocza-ai/wspolpraca-miedzynarodowa'
  },
  {
    id: 'itechlaw',
    name: 'ITechLaw',
    role: 'Co-Chair',
    description: 'Co-Chair of Legal Tech Committee of International Technology Law Association, the leading global organization for technology law professionals, fostering collaboration and knowledge exchange.',
    logo: '/images/logos/itechlaw.jpg',
    link: 'https://www.itechlaw.org/committee-type/legal-technology-committee/'
  },
  {
    id: 'piit',
    name: 'PIIT',
    role: 'Expert',
    description: 'AI Expert of the Breakthrough Technologies Committee at the Polish Chamber of Information Technology and Telecommunications (Polska Izba Informatyki i Telekomunikacji), representing the ICT industry in Poland.',
    logo: '/images/logos/piit.png',
    link: 'https://piit.org.pl/o-nas/eksperci/michal-jackowski'
  },
  {
    id: 'cen-cenelec',
    name: 'CEN-CENELEC',
    role: 'Expert',
    description: 'Member of the CEN and CENELEC Joint Technical Committee 21 (JTC 21), European Committee for Standardization, contributing to the development of technical standards for AI systems in Europe.',
    logo: '/images/logos/cen-cenelec.svg',
    link: 'https://www.cencenelec.eu/areas-of-work/cen-cenelec-topics/artificial-intelligence/'
  },
  {
    id: 'pkn',
    name: 'PKN',
    role: 'Expert',
    description: 'Member of PKN/KT 338 Artificial Intelligence Technical Committee at the Polish Committee for Standardization (Polski Komitet Normalizacyjny), working on national and international AI standardization efforts.',
    logo: '/images/logos/pkn.png',
    link: 'https://www.pkn.pl/informacje/2024/01/pknkt-338-ds-sztucznej-inteligencji'
  },
  {
    id: 'itcorner',
    name: 'ITCORNER',
    role: 'Former Board Member',
    description: 'Former Member of Management Board and ongoing member of ITCORNER VOICE. The largest Polish organization bringing together Polish founders of technology companies, promoting innovation and digital transformation in the technology sector.',
    logo: '/images/logos/itcorner.png',
    link: 'https://itcorner.org.pl/o-nas/nasz-zespol/'
  },
  {
    id: 'luminai',
    name: 'LumiAI',
    role: 'Advisory Board',
    description: 'Member of the Programme Council (Rada Programowa) of LumiAI, an organization focused on AI education and responsible AI adoption in Poland.',
    logo: '/images/logos/luminai.svg',
    link: 'https://www.luminai.pl/czlonek-rady/prof-michal-jackowski'
  },
  {
    id: 'gracehopper',
    name: 'GraceHopper Institute',
    role: 'Supervisory Board',
    description: 'Member of the Supervisory Board of GraceHopper Institute, an NGO promoting diversity and inclusion in technology.',
    logo: '/images/logos/gracehopper.svg',
    link: 'https://gracehopperinstitute.org/staff-amp-faculty/michal-jackowski/'
  },
  {
    id: 'quantum',
    name: 'European Quantum Intelligence Foundation',
    role: 'Board Member',
    description: 'Board Member of the European Quantum Intelligence Foundation (Europejska Fundacja Quantum Intelligence), focused on education in breakthrough technologies and promoting knowledge of quantum computing in Poland.',
    logo: '/images/logos/quantum.svg',
    link: null
  }
];
---

<BaseLayout title="Governance - AI Policy & Standards | Prof. Michał Jackowski" lang="en">
  <Header lang="en" />
  <main>
    <!-- Hero -->
    <section class="py-16 md:py-24 bg-gray-50">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <p class="text-small text-blue font-medium uppercase tracking-wide mb-4">Governance</p>
        <h1 class="text-display text-navy mb-6">AI Policy & International Standards</h1>
        <p class="text-h2 text-slate max-w-2xl">
          Shaping the governance of artificial intelligence through policy work, standardization, and international cooperation.
        </p>
      </div>
    </section>

    <!-- Organizations -->
    <section class="py-16 md:py-20">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <div class="space-y-8">
          {organizations.map((org) => (
            <div id={org.id} class="bg-white p-6 md:p-8 rounded-lg border border-gray-200 hover:border-blue transition-colors">
              <div class="flex flex-col md:flex-row gap-6 items-start">
                <div class="flex-shrink-0">
                  <img
                    src={org.logo}
                    alt={org.name}
                    class="h-12 md:h-16 w-auto object-contain"
                  />
                </div>
                <div class="flex-1">
                  <div class="flex flex-wrap items-center gap-3 mb-2">
                    <h2 class="text-h1 text-navy">{org.name}</h2>
                    <span class="text-caption text-blue bg-blue/10 px-2 py-1 rounded font-medium">
                      {org.role}
                    </span>
                  </div>
                  <p class="text-body text-slate mb-4">
                    {org.description}
                  </p>
                  {org.links ? (
                    <div class="flex flex-wrap gap-4">
                      {org.links.map((link: {label: string, url: string}) => (
                        <a
                          href={link.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="inline-flex items-center gap-1 text-small text-blue font-medium hover:underline"
                        >
                          {link.label} <span>↗</span>
                        </a>
                      ))}
                    </div>
                  ) : org.link ? (
                    <a
                      href={org.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1 text-small text-blue font-medium hover:underline"
                    >
                      Learn more <span>↗</span>
                    </a>
                  ) : null}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Focus Areas -->
    <section class="py-16 md:py-20 bg-gray-50">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <h2 class="text-h1 text-navy mb-8">Focus Areas</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <div class="bg-white p-6 rounded-lg border border-gray-200">
            <h3 class="text-h2 text-navy mb-2">EU AI Act</h3>
            <p class="text-body text-slate">
              Implementation guidance and compliance frameworks for the landmark AI regulation.
            </p>
          </div>
          <div class="bg-white p-6 rounded-lg border border-gray-200">
            <h3 class="text-h2 text-navy mb-2">Data Governance</h3>
            <p class="text-body text-slate">
              Data Act, Data Governance Act, and comprehensive data management frameworks.
            </p>
          </div>
          <div class="bg-white p-6 rounded-lg border border-gray-200">
            <h3 class="text-h2 text-navy mb-2">Cybersecurity</h3>
            <p class="text-body text-slate">
              NIS2, cyber resilience, and security frameworks for AI systems and digital infrastructure.
            </p>
          </div>
          <div class="bg-white p-6 rounded-lg border border-gray-200">
            <h3 class="text-h2 text-navy mb-2">Human Oversight</h3>
            <p class="text-body text-slate">
              Frameworks for meaningful human control over AI systems and automated decision-making.
            </p>
          </div>
          <div class="bg-white p-6 rounded-lg border border-gray-200">
            <h3 class="text-h2 text-navy mb-2">GPAI Models</h3>
            <p class="text-body text-slate">
              Governance frameworks for general-purpose AI models and foundation model providers.
            </p>
          </div>
          <div class="bg-white p-6 rounded-lg border border-gray-200">
            <h3 class="text-h2 text-navy mb-2">Data Protection</h3>
            <p class="text-body text-slate">
              GDPR compliance, privacy frameworks, and data protection in AI systems.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Professional Associations -->
    <section class="py-16 md:py-20">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <h2 class="text-h1 text-navy mb-4">Professional Associations</h2>
        <p class="text-body text-slate mb-8">Active member of leading international organizations in AI, law, and technology governance.</p>
        <div class="flex flex-wrap gap-4">
          <a href="https://www.iaail.org/" target="_blank" rel="noopener noreferrer" class="px-4 py-2 bg-gray-100 text-slate rounded-lg hover:bg-blue hover:text-white transition-colors">International Association of Artificial Intelligence & Law</a>
          <a href="https://www.worldjurist.org/" target="_blank" rel="noopener noreferrer" class="px-4 py-2 bg-gray-100 text-slate rounded-lg hover:bg-blue hover:text-white transition-colors">World Jurist Association</a>
          <a href="https://www.icon-society.org/" target="_blank" rel="noopener noreferrer" class="px-4 py-2 bg-gray-100 text-slate rounded-lg hover:bg-blue hover:text-white transition-colors">ICON-S</a>
          <a href="https://sipe-online.eu/" target="_blank" rel="noopener noreferrer" class="px-4 py-2 bg-gray-100 text-slate rounded-lg hover:bg-blue hover:text-white transition-colors">Societas Iuris Publici Europaei (SIPE)</a>
          <a href="https://www.giga-net.org/" target="_blank" rel="noopener noreferrer" class="px-4 py-2 bg-gray-100 text-slate rounded-lg hover:bg-blue hover:text-white transition-colors">GigaNet</a>
          <a href="https://worldtechlegal.com/" target="_blank" rel="noopener noreferrer" class="px-4 py-2 bg-gray-100 text-slate rounded-lg hover:bg-blue hover:text-white transition-colors">World Tech Legal</a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 md:py-20 bg-navy">
      <div class="max-w-content mx-auto px-6 lg:px-12 text-center">
        <h2 class="text-h1 text-white mb-4">Interested in AI Governance?</h2>
        <p class="text-body text-gray-300 mb-8">
          Let's discuss AI policy, regulation, and standardization.
        </p>
        <a
          href="/en/contact"
          class="inline-block px-8 py-3 bg-white text-navy font-medium rounded hover:bg-gray-100 transition-colors"
        >
          Get in touch
        </a>
      </div>
    </section>
  </main>
  <Footer lang="en" />
</BaseLayout>
