---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

const popularEpisodes = [
  {
    title: 'AI, Hollywood i Prawo: Cyfrowe podobizny, kreatywność i zaufanie prawne',
    description: 'Jak AI przekształca branżę kreatywną, prawa do cyfrowych podobizn i ewoluujące ramy prawne wokół treści generowanych przez AI.',
    youtubeUrl: 'https://youtu.be/SaR7_bVyUG0',
    thumbnail: 'https://img.youtube.com/vi/SaR7_bVyUG0/hqdefault.jpg'
  },
  {
    title: 'Inside Harvey: Przyszłość Legal AI',
    description: 'Rozmowa z Gabe Pereyra o Harvey, jednej z wiodących platform legal AI, i jak przekształca praktykę prawną.',
    youtubeUrl: 'https://youtu.be/sXZHWLL4-9A',
    thumbnail: 'https://img.youtube.com/vi/sXZHWLL4-9A/hqdefault.jpg'
  },
  {
    title: 'Quantum computing bez mitów i marketingu',
    description: 'Głęboka analiza quantum computing ze Sławomirem Soszyńskim - oddzielenie rzeczywistości od marketingowego szumu.',
    youtubeUrl: 'https://youtu.be/uScW6Ucj9u4',
    thumbnail: 'https://img.youtube.com/vi/uScW6Ucj9u4/hqdefault.jpg'
  }
];

const speakingAgencies = [
  { name: 'Cyber Security Speakers', url: 'https://cyber-security-speakers.com/speaker/prof-michal-jackowski' },
  { name: 'AI Speakers Agency', url: 'https://ai-speakers-agency.com/speaker/michal-jackowski' },
  { name: 'Champions Speakers', url: 'https://champions-speakers.co.uk/speaker-agent/michal-jackowski' }
];

const mediaAppearances = [
  { title: 'Prawno-biznesowe aspekty sztucznej inteligencji', outlet: 'RDC Radio · Magazyn Ekonomiczny', url: 'https://www.rdc.pl/podcast/magazyn-ekonomiczny_UTwfU2vb8FOR2vCLz4fL?episode=qg0Q0m7RUC2YzdYhqOJz&active_page=1', type: 'radio', description: 'Dyskusja o regulacjach AI i ich wpływie na biznes w Polsce.' },
  { title: 'Przywództwo w świecie AI okiem prawnika', outlet: 'Values Podcast', url: 'https://values.pl/podcast/przywodztwo-w-swiecie-ai-okiem-wybitnego-prawnika/', type: 'podcast', description: 'Przywództwo w erze AI z perspektywy prawnej.' },
  { title: 'Wywiad Dzień Dobry TVN', outlet: 'TVN', url: 'https://player.pl/programy-online/dzien-dobry-tvn-odcinki,15232/odcinek-381,S28E381,201407', type: 'tv', description: 'Poranny program o sztucznej inteligencji w codziennym życiu.' },
  { title: 'AI w praktyce prawniczej', outlet: 'Keystory', url: 'https://www.youtube.com/watch?v=8wV5lXB85y8', type: 'video', description: 'Jak AI zmienia codzienną pracę prawników i kancelarii.' },
  { title: 'Przyszłość regulacji AI', outlet: 'InfoShare', url: 'https://www.youtube.com/watch?v=BBxlQxA2FGw', type: 'video', description: 'Panel dyskusyjny o nadchodzących regulacjach AI w Europie.' },
  { title: 'Innowacje Legal Tech', outlet: 'Targi Książki', url: 'https://www.youtube.com/watch?v=5jFqdTw7ADc', type: 'video', description: 'Jak AI zmienia branżę wydawniczą i prawo autorskie.' },
  { title: 'AI i prawo - dyskusja', outlet: 'Escola Mobile', url: 'https://www.youtube.com/watch?v=pxiAFZDGSNY', type: 'video', description: 'Prawne aspekty wdrażania sztucznej inteligencji.' },
  { title: 'Regulacje technologiczne', outlet: 'Taby vs Space', url: 'https://www.youtube.com/watch?v=JHBaYZ8XIZM', type: 'video', description: 'Czy AI w IT jest legalne? Dyskusja o regulacjach technologicznych.' },
  { title: 'Panel ekspertów AI Governance', outlet: 'SoDA Webinar', url: 'https://www.youtube.com/watch?v=q12Z-GHhgLg', type: 'video', description: 'Panel ekspercki o governance AI i HR w branży tech.' }
];

const mediaIcons = {
  radio: '📻',
  podcast: '🎙️',
  tv: '📺',
  video: '▶️'
};

// Najnowsze konferencje
const recentConferences = [
  { title: 'Kongres Ochrony Danych i Nowych Technologii', event: 'Panel: Regulacje AI i danych w UE, Chinach i USA', url: 'https://uodo.gov.pl/pl/643/4035', year: '2026', type: 'ailaw', location: 'Warszawa', org: 'UODO' },
  { title: 'PINT 2025', event: 'Konferencja Legal Innovation', url: 'https://pint24.oirp.krakow.pl/agenda/', year: '2025', type: 'legaltech', location: 'Kraków', org: 'OIRP' },
  { title: 'Pozitive Tech 2025', event: 'Konferencja Tech', url: 'https://pozitive.tech/prelegenci-zestawien/prof-michal-jackowski/', year: '2025', type: 'tech', location: 'Poznań', org: '' },
  { title: 'ICAIL 2025', event: 'Międzynarodowa Konferencja AI & Prawo', url: 'https://sites.northwestern.edu/icail2025/agenda/', year: '2025', type: 'ailaw', location: 'Chicago', org: '' },
  { title: 'LegalTech Talk 2025', event: 'Konferencja Międzynarodowa', url: 'https://www.legaltech-talk.com/agenda-2025/', year: '2025', type: 'legaltech', location: 'Berlin', org: '' },
  { title: 'Rzeszów AI Summit 2025', event: 'AI dla Prawa, Nauki i Społeczeństwa', url: 'https://www.ur.edu.pl/pl/konferencje/rzeszow-ai-summit-2025-next-generation-artificial-intelligence-for-law-science-innovation-and-society/prelegenci', year: '2025', type: 'ailaw', location: 'Rzeszów', org: '' }
];

// Pozostałe konferencje
const otherConferences = [
  { title: 'FutureLaw 2024', event: 'Innowacje Prawne', url: 'https://futurelaw.ee/futurelaw-2024/', year: '2024', type: 'legaltech', location: 'Tallinn' },
  { title: 'World Technology Law Conference', event: 'ITechLaw', url: 'https://dsk-kancelaria.pl/en/legal-innovations/michal-jackowski-at-world-technology-law-conference-2024/', year: '2024', type: 'legaltech', location: 'Bruksela' },
  { title: 'ML in PL Conference', event: 'Machine Learning', url: 'https://conference2024.mlinpl.org', year: '2024', type: 'tech', location: 'Warszawa' },
  { title: 'Upgrade 2024', event: 'Konferencja Biznesowa', url: 'https://letsupgrade.pl/upgrade2024', year: '2024', type: 'business', location: 'Warszawa' },
  { title: 'Konferencja ILC', event: 'Innowacje Prawne', url: 'https://konferencja.ilc.com.pl', year: '2024', type: 'legaltech', location: 'Warszawa' },
  { title: 'InfoShare', event: 'Konferencja Tech', url: 'https://infoshare.pl/speakers-list/michal-jackowski-o1744g628c48-one.html', year: '2024', type: 'tech', location: 'Gdańsk' },
  { title: 'Open Forum AI', event: 'Konferencja AI', url: 'https://otwarteforumai.pl', year: '2024', type: 'tech', location: 'Warszawa' },
  { title: 'JURIX 2023', event: 'Systemy Wiedzy Prawnej', url: 'https://dsk-kancelaria.pl/en/legal-innovations/michal-jackowski-at-jurix-2023-conference/', year: '2023', type: 'ailaw', location: 'Maastricht' },
  { title: 'ICAIL 2023', event: 'AI & Prawo', url: 'https://dsk-kancelaria.pl/blog/michal-jackowski-na-konferencji-icail-2023/', year: '2023', type: 'ailaw', location: 'Braga' },
  { title: 'IDC CIO Summit', event: 'IT Leadership', url: 'https://dsk-kancelaria.pl/blog/michal-jackowski-na-idc-cio-summit-w-sopocie/', year: '2023', type: 'business', location: 'Sopot' },
  { title: 'Upgrade 2023', event: 'Konferencja Biznesowa', url: 'https://letsupgrade.pl/upgrade23', year: '2023', type: 'business', location: 'Warszawa' },
  { title: 'LPM Conference', event: 'Legal Project Management', url: 'https://lpm-conference-2022.syskonf.pl', year: '2022', type: 'legaltech', location: 'Warszawa' }
];

const conferenceTypes = {
  ailaw: { icon: '⚖️', label: 'AI & Prawo', color: 'bg-blue/10 text-blue' },
  legaltech: { icon: '💼', label: 'Legal Tech', color: 'bg-navy/10 text-navy' },
  tech: { icon: '🤖', label: 'Tech', color: 'bg-purple-100 text-purple-700' },
  business: { icon: '📊', label: 'Biznes', color: 'bg-green-100 text-green-700' }
};

const popularArticles = [
  { title: 'Z AI zostaniesz chemikiem i prawnikiem', outlet: 'Rzeczpospolita', url: 'https://www.rp.pl/rzecz-o-prawie/art41430351-michal-jackowski-michal-araszkiewicz-z-ai-zostaniesz-chemikiem-i-prawnikiem' },
  { title: 'O czym marzą technologicznie prawnicy', outlet: 'Rzeczpospolita', url: 'https://www.rp.pl/rzecz-o-prawie/art40662471-michal-raczkowski-michal-araszkiewicz-o-czym-marza-technologicznie-prawnicy' },
  { title: 'Polski prawnik daleko za światowymi trendami', outlet: 'Rzeczpospolita', url: 'https://www.rp.pl/rzecz-o-prawie/art40464061-michal-jackowski-michal-araszkiewicz-polski-prawnik-daleko-za-swiatowymi' },
  { title: 'AI w praktyce prawa: Polska daleko za trendami', outlet: 'Rzeczpospolita', url: 'https://www.rp.pl/opinie-prawne/art40296431-sztuczna-inteligencja-w-praktyce-prawa-polska-daleko-za-swiatowymi-trendami' },
  { title: 'Sztuczna inteligencja Made in Poland', outlet: 'Gazeta Wyborcza', url: 'https://wyborcza.biz/biznes/7,177150,26997427,sztuczna-inteligencja-made-in-poland-z-cytatami-z-jana-pawla.html' }
];
---

<BaseLayout title="Media - Podcast & Prasa | Prof. Michał Jackowski" lang="pl" alternateUrl="/en/media/">
  <Header lang="pl" />
  <main id="main-content">
    <!-- Hero -->
    <section class="py-16 md:py-24 bg-gray-50">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <p class="text-small text-blue font-medium uppercase tracking-wide mb-4">Media</p>
        <h1 class="text-display text-navy mb-6">Podcast & Obecność Publiczna</h1>
        <p class="text-h2 text-slate max-w-2xl">
          Dzielenie się spostrzeżeniami na temat prawa AI, regulacji technologii i przyszłości praktyki prawnej poprzez podcast Monday Bagel i występy medialne.
        </p>
      </div>
    </section>

    <!-- Monday Bagel Podcast -->
    <section id="podcast" class="py-16 md:py-20">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <div class="bg-navy rounded-2xl p-8 md:p-12 text-white mb-12">
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div>
              <div class="text-5xl mb-4">🥯</div>
              <h2 class="text-h1 text-white mb-4">Monday Bagel</h2>
              <p class="text-body text-gray-300 mb-6">
                Cotygodniowy podcast eksplorujący przecięcie prawa, technologii i sztucznej inteligencji.
                Każdy odcinek dostarcza spostrzeżeń, które możesz przyswoić przy poniedziałkowej kawie (lub bajglu).
              </p>
              <p class="text-body text-gray-300 mb-8">
                Od głębokich analiz regulacyjnych po rozmowy z liderami branży, Monday Bagel sprawia,
                że złożone tematy prawa AI stają się przystępne i praktyczne.
              </p>
              <div class="flex flex-wrap gap-4">
                <a
                  href="https://www.youtube.com/@mjackowski/videos"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block px-6 py-3 bg-white text-navy font-medium rounded hover:bg-gray-100 transition-colors"
                >
                  Przeglądaj odcinki
                </a>
                <a
                  href="https://www.youtube.com/@mjackowski"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-block px-6 py-3 border border-white text-white font-medium rounded hover:bg-white/10 transition-colors"
                >
                  Subskrybuj
                </a>
              </div>
            </div>
            <div class="text-center">
              <div class="inline-block bg-white/10 rounded-xl p-8">
                <p class="text-6xl font-bold mb-2">70+</p>
                <p class="text-small text-gray-300">Odcinków</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Most Popular Episodes -->
        <h3 id="odcinki" class="text-h1 text-navy mb-6">Najpopularniejsze odcinki</h3>
        <div class="grid md:grid-cols-3 gap-6 mb-12">
          {popularEpisodes.map((episode) => (
            <a
              href={episode.youtubeUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="group bg-white rounded-lg border border-gray-200 overflow-hidden hover:border-blue transition-colors"
            >
              <div class="aspect-video bg-gray-100 overflow-hidden">
                <img
                  src={episode.thumbnail}
                  alt={episode.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform"
                />
              </div>
              <div class="p-4">
                <h4 class="text-h2 text-navy mb-2 group-hover:text-blue transition-colors">{episode.title}</h4>
                <p class="text-small text-slate">{episode.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Rankings -->
    <section id="rankingi" class="py-16 md:py-20">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <h2 class="text-h1 text-navy mb-4">Rankingi</h2>
        <p class="text-body text-slate mb-8 max-w-2xl">
          Wyróżnienia w wiodących rankingach branży prawniczej.
        </p>

        <div class="grid md:grid-cols-2 gap-6">
          <a
            href="https://rankingi.rp.pl/rankingkancelarii/2025/rekomendacje_I"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-white p-6 rounded-lg border border-gray-200 hover:border-blue hover:shadow-md transition-all group"
          >
            <div class="flex items-start gap-4">
              <div class="text-4xl">🏆</div>
              <div>
                <p class="text-caption text-blue mb-1">Ranking Rzeczpospolitej 2025</p>
                <h3 class="text-h2 text-navy mb-2 group-hover:text-blue transition-colors">Lider Rynku TMT</h3>
                <p class="text-body text-slate mb-3">
                  Wyróżnienie jako Lider Rynku w kategorii Technologie, Media i Telekomunikacja w Polsce.
                </p>
                <span class="text-small text-blue font-medium">Zobacz ranking →</span>
              </div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Media Appearances -->
    <section id="prasa" class="py-16 md:py-20 bg-gray-50">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <h2 class="text-h1 text-navy mb-4">Wystąpienia medialne</h2>
        <p class="text-body text-slate mb-8 max-w-2xl">
          Cytowany w wiodących publikacjach omawiających regulacje AI, technologie prawne i przyszłość profesji prawniczej.
        </p>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
          {mediaAppearances.map((item) => (
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group bg-white rounded-lg border border-gray-200 hover:border-blue hover:shadow-md transition-all overflow-hidden"
            >
              <div class="h-16 bg-gradient-to-br from-gray-50 to-gray-100 flex items-center justify-center border-b border-gray-100">
                <span class="text-3xl">{mediaIcons[item.type]}</span>
              </div>
              <div class="p-4">
                <p class="text-caption text-blue mb-1">{item.outlet}</p>
                <p class="text-body text-navy font-medium group-hover:text-blue transition-colors mb-2">{item.title}</p>
                <p class="text-small text-slate">{item.description}</p>
              </div>
            </a>
          ))}
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white p-6 rounded-lg border border-gray-200">
            <p class="text-caption text-slate mb-2">Zapytania medialne</p>
            <h3 class="text-h2 text-navy mb-4">Dostępny do komentarza</h3>
            <p class="text-body text-slate mb-4">
              Regularnie dostarczam eksperckiego komentarza na temat prawa AI, regulacji technologii i innowacji prawnych dla dziennikarzy i mediów.
            </p>
            <a
              href="/pl/kontakt"
              class="text-small text-blue font-medium hover:underline"
            >
              Kontakt dla mediów →
            </a>
          </div>

          <div class="bg-white p-6 rounded-lg border border-gray-200">
            <p class="text-caption text-slate mb-2">Wystąpienia</p>
            <h3 class="text-h2 text-navy mb-4">Prelegent na konferencjach</h3>
            <p class="text-body text-slate mb-4">
              Dostępny na keynote'y, panele dyskusyjne i warsztaty o governance AI, legal tech i regulacji technologii.
            </p>
            <a
              href="/pl/kontakt#wystapienia"
              class="text-small text-blue font-medium hover:underline"
            >
              Zaproś do wystąpienia →
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Conferences & Events -->
    <section id="konferencje" class="py-16 md:py-20">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <h2 class="text-h1 text-navy mb-4">Konferencje i wydarzenia</h2>
        <p class="text-body text-slate mb-8 max-w-2xl">
          Wystąpienia na wiodących międzynarodowych konferencjach o prawie AI, technologiach prawnych i cyfrowym governance.
        </p>

        <!-- Najnowsze konferencje -->
        <h3 class="text-h2 text-navy mb-4">Najnowsze</h3>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
          {recentConferences.map((item) => (
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group bg-gradient-to-br from-white to-gray-50 p-5 rounded-xl border border-gray-200 hover:border-blue hover:shadow-lg transition-all"
            >
              <div class="flex items-center justify-between mb-3">
                <span class="text-h1 text-navy/20 font-bold">{item.year}</span>
                <span class={`text-caption px-2 py-1 rounded-full ${conferenceTypes[item.type].color}`}>
                  {conferenceTypes[item.type].icon} {conferenceTypes[item.type].label}
                </span>
              </div>
              <h4 class="text-h2 text-navy mb-1 group-hover:text-blue transition-colors">{item.title}</h4>
              <p class="text-small text-slate mb-3">{item.event}</p>
              <div class="flex items-center justify-between">
                <span class="text-caption text-slate">📍 {item.location}</span>
                <span class="text-small text-blue font-medium opacity-0 group-hover:opacity-100 transition-opacity">Szczegóły →</span>
              </div>
            </a>
          ))}
        </div>

        <!-- Pozostałe konferencje -->
        <h3 class="text-h2 text-navy mb-4">Pozostałe</h3>
        <div class="grid md:grid-cols-3 lg:grid-cols-4 gap-3">
          {otherConferences.map((item) => (
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group bg-white p-4 rounded-lg border border-gray-200 hover:border-blue transition-colors"
            >
              <div class="flex items-center gap-2 mb-2">
                <span class="text-caption text-slate bg-gray-100 px-2 py-0.5 rounded">{item.year}</span>
                <span class="text-sm">{conferenceTypes[item.type].icon}</span>
              </div>
              <p class="text-body text-navy font-medium mb-1 group-hover:text-blue transition-colors">{item.title}</p>
              <p class="text-caption text-slate">{item.event} · {item.location}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Popular Articles -->
    <section id="artykuly" class="py-16 md:py-20 bg-gray-50">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <h2 class="text-h1 text-navy mb-4">Popularne artykuły</h2>
        <p class="text-body text-slate mb-8 max-w-2xl">
          Komentarze i analizy o AI w praktyce prawnej, publikowane w wiodących mediach.
        </p>

        <div class="space-y-4">
          {popularArticles.map((item) => (
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="block bg-white p-4 rounded-lg border border-gray-200 hover:border-blue transition-colors"
            >
              <div class="flex justify-between items-center">
                <div>
                  <p class="text-body text-navy font-medium">{item.title}</p>
                  <p class="text-caption text-slate">{item.outlet}</p>
                </div>
                <span class="text-blue">↗</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Speaking Contact -->
    <section id="wystapienia" class="py-16 md:py-20">
      <div class="max-w-content mx-auto px-6 lg:px-12">
        <h2 class="text-h1 text-navy mb-4">Agencje prelegentów</h2>
        <p class="text-body text-slate mb-8">
          Zarezerwuj wystąpienie poprzez te agencje.
        </p>
        <div class="grid md:grid-cols-3 gap-6">
          {speakingAgencies.map((agency) => (
            <a
              href={agency.url}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-white p-6 rounded-lg border border-gray-200 hover:border-blue transition-colors text-center"
            >
              <p class="text-h2 text-navy hover:text-blue transition-colors">{agency.name}</p>
              <p class="text-small text-blue mt-2">Zobacz profil ↗</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 md:py-20 bg-navy">
      <div class="max-w-content mx-auto px-6 lg:px-12 text-center">
        <h2 class="text-h1 text-white mb-4">Zapytanie medialne?</h2>
        <p class="text-body text-gray-300 mb-8">
          Dostępny na wywiady, ekspercki komentarz i wystąpienia.
        </p>
        <a
          href="/pl/kontakt"
          class="inline-block px-8 py-3 bg-white text-navy font-medium rounded hover:bg-gray-100 transition-colors"
        >
          Skontaktuj się
        </a>
      </div>
    </section>
  </main>
