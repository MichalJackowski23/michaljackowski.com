---
import CookieConsent from '@components/CookieConsent.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'pl';
  image?: string;
  type?: 'website' | 'article';
  alternateUrl?: string; // URL of the alternate language version
}

const {
  title,
  description = "Prof. Michał Jackowski - Legal Scholar, AI Governance Expert, Attorney at Law",
  lang = 'en',
  image = '/images/michal-jackowski.jpg',
  type = 'website',
  alternateUrl
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, 'https://michaljackowski.com');
const imageURL = new URL(image, 'https://michaljackowski.com');
const alternateLang = lang === 'en' ? 'pl' : 'en';
const alternateFullUrl = alternateUrl ? new URL(alternateUrl, 'https://michaljackowski.com').href : null;

// Schema.org Person data
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Michał Jackowski",
  "jobTitle": "Professor of AI & Law",
  "url": "https://michaljackowski.com",
  "image": imageURL.href,
  "sameAs": [
    "https://www.linkedin.com/in/michal-jackowski-prof/"
  ],
  "worksFor": [
    {
      "@type": "Organization",
      "name": "DSK Kancelaria",
      "url": "https://dsk-kancelaria.pl"
    },
    {
      "@type": "Organization",
      "name": "AnyLawyer",
      "url": "https://anylawyer.com"
    },
    {
      "@type": "Organization",
      "name": "SWPS University"
    }
  ],
  "alumniOf": [
    {
      "@type": "Organization",
      "name": "ESCP Europe"
    },
    {
      "@type": "Organization",
      "name": "University of Cambridge"
    }
  ],
  "knowsAbout": ["AI Governance", "AI Act", "Legal Technology", "Data Protection", "Cybersecurity"]
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Hreflang for alternate language versions -->
    <link rel="alternate" hreflang={lang} href={canonicalURL} />
    {alternateFullUrl && (
      <link rel="alternate" hreflang={alternateLang} href={alternateFullUrl} />
    )}
    <link rel="alternate" hreflang="x-default" href="https://michaljackowski.com/en/" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:locale" content={lang === 'pl' ? 'pl_PL' : 'en_US'} />
    <meta property="og:site_name" content="Prof. Michał Jackowski" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <!-- Fonts with display=swap for better performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Source+Serif+Pro:wght@400&display=swap" rel="stylesheet" />

    <!-- Focus styles for accessibility -->
    <style>
      /* Custom focus styles for better visibility */
      :focus-visible {
        outline: 2px solid #2563eb;
        outline-offset: 2px;
      }

      /* Skip link styles */
      .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        padding: 8px 16px;
        background: #0f172a;
        color: white;
        z-index: 100;
        transition: top 0.2s;
      }
      .skip-link:focus {
        top: 0;
      }
    </style>

    <!-- Google Analytics with Consent Mode -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}

      // Default: deny analytics until consent is given
      gtag('consent', 'default', {
        'analytics_storage': 'denied'
      });

      // Check if consent was previously given
      if (localStorage.getItem('cookie-consent') === 'accepted') {
        gtag('consent', 'update', {
          'analytics_storage': 'granted'
        });
      }
    </script>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-GFKMMEDH8V"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-GFKMMEDH8V');
    </script>

    <title>{title}</title>
  </head>
  <body class="font-sans text-navy bg-white antialiased">
    <!-- Skip link for accessibility -->
    <a href="#main-content" class="skip-link">
      {lang === 'pl' ? 'Przejdź do treści' : 'Skip to content'}
    </a>
    <slot />
    <CookieConsent lang={lang} />
  </body>
</html>
